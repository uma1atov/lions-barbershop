# =============================================
# The Lion's Den Barbershop — ENV Config
# Скопируйте в .env и заполните значения
# =============================================
NODE_ENV=production
PORT=3001
BASE_URL=https://your-domain.com

# ─── AUTH & SECURITY ────────────────────────────
JWT_SECRET=change-me-to-random-string-min-32-chars
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=12

# ─── OWNER ADMIN (auto-seed on first start) ─────
OWNER_ADMIN_PHONE=+79001234567
OWNER_ADMIN_PASSWORD=change-me
OWNER_ADMIN_NAME=Admin
OWNER_ADMIN_EMAIL=admin@example.com

# ─── ADMIN LIMITS ───────────────────────────────
MAX_ADMINS=3
MAX_OWNER_ADMINS=2

# ─── EMAIL (SMTP для восстановления пароля) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# =============================================
# TELEGRAM
# =============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=my-secret-token-123
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BARBER_CHAT_IDS=

# =============================================
# WHATSAPP
# =============================================
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_VERIFY_TOKEN=my-wa-verify-token
META_WA_APP_SECRET=

# =============================================
# ПЛАНИРОВЩИК
# =============================================
JOB_WORKER_ENABLED=true
JOB_CHECK_INTERVAL=30
MIN_BOOKING_LEAD_MINUTES=0
